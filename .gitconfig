[core]
    editor = lvim
[user]
	name = Øyvind Ødegård
[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
[diff]
    tool = difftastic
    external = difft
[difftool]
    prompt = false
[difftool "difftastic"]
    cmd = difft "$LOCAL" "$REMOTE"
[pager]
    difftool = true
[includeIf "gitdir:~/git/github.com/CatalystOne/"]
	path = ~/.gitconfig-github-oodegard
[includeIf "gitdir:~/git/github.com/whirlwin/"]
	path = ~/.gitconfig-github-whirlwin
[includeIf "gitdir:~/git/codeberg.org/whirlwin/"]
	path = ~/.gitconfig-codeberg-whirlwin
